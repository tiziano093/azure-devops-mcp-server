{
  "name": "azure-devops-mcp-server",
  "version": "1.0.0",
  "description": "Modular MCP server for complete Azure DevOps integration.",
  "license": "Apache-2.0",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tiziano093/azure-devops-mcp-server.git"
  },
  "bugs": {
    "url": "https://github.com/tiziano093/azure-devops-mcp-server/issues"
  },
  "homepage": "https://github.com/tiziano093/azure-devops-mcp-server#readme",
  "bin": {
    "azure-devops-mcp-server": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "config"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "dev": "tsx src/index.ts",
    "dev:http": "tsx src/http.ts",
    "start": "node dist/index.js",
    "start:http": "node dist/http.js",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.17.5",
    "azure-devops-node-api": "^14.1.0",
    "dotenv": "^17.4.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "rimraf": "^6.0.1",
    "tsx": "^4.19.1",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "azure-devops",
    "mcp",
    "model-context-protocol",
    "typescript",
    "server"
  ]
}
